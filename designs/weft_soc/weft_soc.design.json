   {"name":"MEM_WORDS","type":"int unsigned","default":"16384"},
   {"name":"UART_CPB","type":"int unsigned","default":"868"},
   {"name":"RESET_ADDR","type":"logic [31:0]","default":"32'h8000_0000"}],
 "instances":[
